# DAIO Wallet Environment Variables

# ── Alchemy (Real Blockchain Data) ────────────────────────────────────────────
# Sign up at https://www.alchemy.com — free tier is sufficient for development.
# When set, Alchemy RPC replaces public endpoints for better reliability.
# Also enables: transaction history, NFT balances, enhanced token data.
VITE_ALCHEMY_API_KEY=

# ── WalletConnect (optional) ──────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=
